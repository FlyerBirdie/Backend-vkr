# PostgreSQL
DATABASE_URL=postgresql://postgres@localhost:5432/production_planning

# CORS: фронт на Vite/React (через запятую). * — разрешить любые источники (только разработка).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# SQLAlchemy: лог SQL (true/false)
SQL_ECHO=false

# Календарь участка и пользовательские пояснения (IANA, по умолчанию Самара)
APP_TIMEZONE=Europe/Samara

# --- JWT (роль planner) ---
# Секрет для подписи HS256; в продакшене длинная случайная строка (≥32 символов).
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key-min-32-chars
JWT_EXPIRE_MINUTES=480

PLANNER_USERNAME=planner
PLANNER_PASSWORD=planner
# В продакшене храните только хэш bcrypt (пароль не хранить в .env):
# PLANNER_PASSWORD_HASH=<вывод: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt'],deprecated='auto').hash('ВАШ_ПАРОЛЬ'))">
# Для локальной разработки можно временно задать открытый пароль (не для продакшена):
# PLANNER_PASSWORD=dev-only-password
